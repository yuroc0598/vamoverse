{
  "name": "vamoverse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx src/lib/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run tests/smoke",
    "test:coverage": "vitest run --coverage",
    "ios:init": "cap init Vamoverse com.vamoverse.app --web-dir=out",
    "ios:add": "cap add ios",
    "ios:build": "next build",
    "ios:build:static": "CAPACITOR_EXPORT=true next build",
    "ios:sync": "cap sync ios",
    "ios:open": "cap open ios",
    "ios:dev": "next build && cap sync ios && cap open ios",
    "ios:livereload": "cap run ios --external --livereload --host=0.0.0.0 --port=3000",
    "ios:run": "bash scripts/ios.sh run",
    "ios:go": "bash scripts/ios.sh go",
    "ios:logs": "bash scripts/ios.sh logs",
    "ios:ip": "bash scripts/ios.sh ip",
    "ios:device": "bash scripts/ios.sh device"
  },
  "dependencies": {
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@hookform/resolvers": "^3.6.0",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.51.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.400.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "rrule": "^2.8.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.6",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
