# ---------------------------------------------------------------------------
# Vamoverse environment
#
# Leave DATABASE_URL and REDIS_URL empty for the zero-infra MOCK demo (default):
#   - data comes from src/lib/domain/catalog.ts
#   - registration / rate-limit / webhook-dedup use in-memory stores
#
# Set them (e.g. via `docker compose up -d`) to switch to the REAL backend:
#   - registration becomes atomic (Postgres FOR UPDATE, no overbooking)
#   - payment idempotency + webhook dedup + rate limits become durable/shared
# ---------------------------------------------------------------------------

# Supabase (auth). Value containing "localhost"/"mock" -> mock auth mode.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.mock
SUPABASE_SERVICE_ROLE_KEY=mock-service-role-key

# Real data layer (optional). When set, the app uses Postgres + Redis.
# docker compose defaults:
# DATABASE_URL=postgres://vamoverse:vamoverse@localhost:5432/vamoverse
# REDIS_URL=redis://localhost:6379
DATABASE_URL=
REDIS_URL=

# Third-party
NEXT_PUBLIC_GOOGLE_PLACES_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=

# Secrets for server-authenticated endpoints
CRON_SECRET=
VAMOS_HMAC_SECRET=

# Behavior
AUTO_CAPTURE_DELAY_MINUTES=2
NEXT_PUBLIC_APP_URL=http://localhost:3000
